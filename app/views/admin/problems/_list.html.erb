<table class="table table-striped">
  <thead>
    <tr>
      <th><%= Problem.human_attribute_name(:image) %></th>
      <th><%= Problem.human_attribute_name(:title) %></th>
      <th><%= Problem.human_attribute_name(:reported_at) %></th>
      <th><%= Problem.human_attribute_name(:reports) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% problems.each do |problem| %>
      <tr>
        <td><%= image_tag problem.image, class: 'thumb', width: 200 if problem.image.attached?  %></td>
        <td><%= link_to problem.title, [:admin, problem] %></td>
        <td><%= l problem.reported_at.to_date, format: '%m/%Y' %></td>
        <td><%= problem.reports.count %></td>
        <td class="text-end">
          <%= link_to t('admin.show'), [:admin, problem], class: button_classes %>
          <%= link_to t('admin.edit'), [:edit, :admin, problem], class: button_classes %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
