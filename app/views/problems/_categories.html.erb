<ul class="problem-categories list-unstyled">
  <%
  Taxonomy.all.ordered.each do |taxonomy|
    categories = problem.categories.where(taxonomy: taxonomy).ordered
    next if categories.none?
    %>
      <li class="mb-4">
        <span class="h5 d-block md-2"><%= taxonomy %></span>
        <ul class="list-unstyled">
          <% categories.each do |category| %>
            <li class="btn badge btn-outline-dark">
              <%= link_to category,
                          category_path(taxonomy_slug: category.taxonomy.slug, category_slug: category.slug),
                          class: 'text-decoration-none fw-normal text-black' %>
            </li>
          <% end %>
        </ul>
      </li>
  <% end %>
</ul>